{
  "manifest_version": 3,
  "name": "Cognify – Smart Study Automation for Your Browser",
  "version": "3.8.0",
  "description": "Cognify supercharges your browser with smart study automation — screen-time limits, focus mode, ad-skip, cloud-synced bookmarks, universal video controls, and real-time watch analytics across YouTube, Instagram, and Facebook.",
  "author": "Mahmud Nibir",
  "homepage_url": "https://github.com/mahmudnibir/yt-extension-enhanced",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "downloads", "webRequest"],
  "host_permissions": ["*://www.youtube.com/*", "<all_urls>"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["src/edge-hud.js", "src/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/video-hover.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": ["*://www.instagram.com/*", "*://www.facebook.com/*", "*://www.fb.com/*"],
      "js": ["src/edge-hud.js", "src/social-download.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  }
}
